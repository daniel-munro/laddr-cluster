rule combined_pheno_groups:
    """Group phenotypes by gene for tensorQTL"""
    input:
        bed = working_dir / 'qtl' / 'all-{version}.bed.gz',
    output:
        groups = working_dir / 'qtl' / 'all-{version}.phenotype_groups.txt',
    shell:
        """
        zcat {input.bed} | tail -n+2 | cut -f4 | awk -F'[:.]' '{{print $0"\t"$2}}' > {output.groups}
        """

rule prune_for_covar:
    """Prune genotypes to compute covariate PCs.
    --indep-pairwise parameters are based on GTEx methods.
    """
    input:
        geno = multiext(geno_prefix, '.bed', '.bim', '.fam'),
    output:
        vcf = working_dir / 'covar' / 'geno_pruned.vcf.gz',
    params:
        geno_prefix = geno_prefix,
        covar_dir = working_dir / 'covar',
        pruned_prefix = working_dir / 'covar' / 'geno_pruned',
    shell:
        # --geno 0.05 filters variants with >5% missing values (the rest will be imputed).
        # Default is 0 so that samples with many more genotyped variants than others don't
        # result in other samples having mostly missing values after pruning.
        """
        mkdir -p {params.covar_dir}
        plink2 \
            --bfile {params.geno_prefix} \
            --geno 0.00 \
            --maf 0.05 \
            --indep-pairwise 200 100 0.1 \
            --out {params.pruned_prefix}
        plink2 \
            --bfile {params.geno_prefix} \
            --extract {params.pruned_prefix}.prune.in \
            --export vcf bgz id-paste=iid \
            --out {params.pruned_prefix}
        """

rule covariates:
    """Compute genotype and expression PCs and combine."""
    input:
        vcf = working_dir / 'covar' / 'geno_pruned.vcf.gz',
        bed = working_dir / 'qtl' / '{phenos}.bed.gz',
    output:
        covar = working_dir / 'covar' / '{phenos}.covar.tsv',
    params:
        n_geno_pcs = 5,
        n_pheno_pcs = 20,
    resources:
        mem_mb = lambda w, attempt: 32000 * 2**(attempt-1),
    retries: 2
    shell:
        """
        Rscript ~/tools/Pantry/Pheast/scripts/covariates.R \
            {input.vcf} \
            {input.bed} \
            {params.n_geno_pcs} \
            {params.n_pheno_pcs} \
            {output.covar}
        """

######################
## Genetic analysis ##
######################

rule tensorqtl_perm:
    """Map cis-QTLs, determining significance using permutations.
    Outputs the top association per phenotype.
    """
    input:
        geno = multiext(geno_prefix, '.bed', '.bim', '.fam'),
        bed = working_dir / 'qtl' / '{phenos}.bed.gz',
        bedi = working_dir / 'qtl' / '{phenos}.bed.gz.tbi',
        covar = working_dir / 'covar' / '{phenos}.covar.tsv',
        groups = working_dir / 'qtl' / '{phenos}.phenotype_groups.txt',
    output:
        qtl = working_dir / 'qtl' / '{phenos}.cis_qtl.txt.gz',
    params:
        geno_prefix = geno_prefix,
    resources:
        mem_mb = lambda w, attempt: 32000 * 2**(attempt-1),
        runtime = '12h',
        # Define slurm_partition, slurm_account, and slurm_extra for GPU jobs as needed in the Snakemake profile config.yaml
    retries: 2
    shell:
        """
        python ~/tools/Pantry/Pheast/scripts/run_tensorqtl.py \
            {params.geno_prefix} \
            {input.bed} \
            {output.qtl} \
            --covariates {input.covar} \
            --groups {input.groups} \
            --mode cis
        """

rule tensorqtl_independent:
    """Use stepwise regression to identify multiple conditionally independent cis-QTLs per phenotype."""
    input:
        geno = multiext(geno_prefix, '.bed', '.bim', '.fam'),
        bed = working_dir / 'qtl' / '{phenos}.bed.gz',
        bedi = working_dir / 'qtl' / '{phenos}.bed.gz.tbi',
        covar = working_dir / 'covar' / '{phenos}.covar.tsv',
        groups = working_dir / 'qtl' / '{phenos}.phenotype_groups.txt',
        cis = working_dir / 'qtl' / '{phenos}.cis_qtl.txt.gz',
    output:
        qtl = working_dir / 'qtl' / '{phenos}.cis_independent_qtl.txt.gz',
    params:
        geno_prefix = geno_prefix,
    resources:
        mem_mb = lambda w, attempt: 32000 * 2**(attempt-1),
        runtime = '20h',
        # Define slurm_partition, slurm_account, and slurm_extra for GPU jobs as needed in the Snakemake profile config.yaml
    retries: 2
    shell:
        """
        python ~/tools/Pantry/Pheast/scripts/run_tensorqtl.py \
            {params.geno_prefix} \
            {input.bed} \
            {output.qtl} \
            --covariates {input.covar} \
            --cis_output {input.cis} \
            --groups {input.groups} \
            --mode cis_independent
        """

