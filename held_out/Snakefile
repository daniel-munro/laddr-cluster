rule assemble_latent_bed:
    """Add gene info to latent phenotypes to generate BED file"""
    input:
        phenos = working_dir / '{resid}' / 'phenotypes' / 'latent_phenos.Geuvadis.tsv.gz',
        ref_anno = ref_anno,
    output:
        bed = working_dir / 'qtl' / 'latent-{resid}.unnorm.bed',
    params:
        qtl_dir = working_dir / 'qtl',
    resources:
        mem_mb = 16000,
    shell:
        """
        mkdir -p {params.qtl_dir}
        python3 ~/tools/Pantry/Project/scripts/assemble_bed.py \
            --type latent \
            --input {input.phenos} \
            --ref_anno {input.ref_anno} \
            --output {output.bed}
        """

rule normalize_latent:
    """Quantile-normalize values for QTL mapping"""
    input:
        bed = working_dir / 'qtl' / 'latent-{params}.unnorm.bed',
        samples = input_dir / 'samples.txt',
    output:
        bed = working_dir / 'qtl' / 'latent-{params}.bed.gz',
    params:
        bed = str(working_dir / 'qtl' / 'latent-{params}.bed'),
    resources:
        mem_mb = 16000,
    shell:
        """
        python3 ~/tools/Pantry/Project/scripts/normalize_phenotypes.py \
            --input {input.bed} \
            --samples {input.samples} \
            --output {params.bed}
        bgzip {params.bed}
        """

def pantry_phenos_input(wildcards):
    mods = [m for m in modalities if m != wildcards.modality]
    assert len(mods) == len(modalities) - 1
    paths = expand(pantry_phenos_dir / '{modality}.bed.gz', modality=mods)
    return paths

rule assemble_combined_bed_latent:
    """Combine Pantry phenotypes and latent phenotypes"""
    input:
        pantry_phenos = pantry_phenos_input,
        latent_phenos = working_dir / 'qtl' / 'latent-no_{modality}.bed.gz',
    output:
        bed = working_dir / 'qtl' / 'all-no_{modality}.bed.gz',
    params:
        qtl_dir = working_dir / 'qtl',
        tmp_bed = str(working_dir / 'qtl' / 'all-no_{modality}_tmp.bed'),
        bed = str(working_dir / 'qtl' / 'all-no_{modality}.bed'),
    resources:
        mem_mb = 16000,
    shell:
        """
        # First confirm that all bed files have the same header:
        for phenos in {input.pantry_phenos}; do
            diff <(zcat {input.pantry_phenos[0]} | head -n 1) <(zcat $phenos | head -n 1)
        done
        diff <(zcat {input.pantry_phenos[0]} | head -n 1) <(zcat {input.latent_phenos} | head -n 1)
        rm -rf {params.tmp_bed}
        for phenos in {input.pantry_phenos}; do
            echo $phenos
            # Prepend modality name to phenotype names:
            modality=$(basename $phenos .bed.gz)
            zcat $phenos | tail -n+2 | awk -v OFS='\t' -v mod=$modality '{{$4 = mod":"$4; print}}' >> {params.tmp_bed}
        done
        zcat {input.latent_phenos} | tail -n+2 | awk -v OFS='\t' '{{$4 = "latent_residual:"$4; print}}' >> {params.tmp_bed}
        zcat {input.pantry_phenos[0]} | head -n1 > {params.bed} || true
        sort -k1,1 -k2,2n {params.tmp_bed} >> {params.bed}
        rm {params.tmp_bed}
        bgzip {params.bed}
        """

rule index_bed:
    """Index a BED file."""
    input:
        bed = working_dir / 'qtl' / '{fname}.bed.gz',
    output:
        tbi = working_dir / 'qtl' / '{fname}.bed.gz.tbi'
    shell:
        'tabix {input.bed}'

