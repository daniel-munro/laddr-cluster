rule inspect_model:
    """Get stats for a latent phenotyping model"""
    input:
        phenos = working_dir / 'latent-{version}.tsv.gz',
    output:
        tsv = working_dir / 'inspect/model_info.{version}.{gene_id}.tsv',
    shell:
        """
        python ~/tools/latent-rna/scripts/inspect_model.py \
            -g {wildcards.gene_id} \
            --bigwig-paths-file covg_bigwig_files.txt \
            --bins-dir gene_bins \
            --norm-covg-dir covg_norm-{wildcards.version} \
            --models-dir models-{wildcards.version} \
            --phenotypes latent-{wildcards.version}.tsv.gz \
            -o inspect/model_info.{wildcards.version}.{wildcards.gene_id}.tsv
        """
