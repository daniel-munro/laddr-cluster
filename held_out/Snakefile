from pathlib import Path

input_dir = Path('../data/input')
pantry_phenos_dir = Path('../../pantry/Geuvadis/output')
working_dir = Path('.')
ref_anno = '../../pantry/Geuvadis/input/human_ref/Homo_sapiens.GRCh38.106.gtf'
geno_prefix = '../../pantry/Geuvadis/input/genotype/GEUVADIS.445_samples.GRCh38.20170504.maf01.filtered.nodup.nochr.chr1-22'

modalities = ['alt_polyA', 'alt_TSS', 'expression', 'isoforms', 'splicing', 'stability']
# modalities = ['alt_polyA']

localrules:
    # latent_pheno_groups,
    combined_pheno_groups,

rule all:
    input:
        expand(working_dir / 'qtl' / 'all-no_{modality}.bed.gz', modality=modalities),
        expand(working_dir / 'qtl' / 'all-no_{modality}.phenotype_groups.txt', modality=modalities),
        expand(working_dir / 'covar' / 'all-no_{modality}.covar.tsv', modality=modalities),
        expand(working_dir / 'qtl' / 'all-no_{modality}.cis_independent_qtl.txt.gz', modality=modalities),

