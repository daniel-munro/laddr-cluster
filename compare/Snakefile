rule count_bins_phenos_qtls:
    """Count the number of bins, phenotypes, and QTLs for each binning and model setting."""
    input:
        bins = expand('{param}/gene_bins/batch_{batch}.bed.gz', param=params, batch=range(N_BATCHES)),
        phenos = expand('{param}/phenotypes/latent_phenos.Geuvadis.tsv.gz', param=params),
        phenos_tested = expand('qtl/latent-{param}.phenotype_groups.txt', param=params),
        qtls = expand('qtl/latent-{param}.cis_independent_qtl.txt.gz', param=params),
    output:
        tsv = 'bin_pheno_qtl_counts.tsv',
    params:
        params = params,
    shell:
        """
        echo -e "type\tparam\tn_bins\tn_phenos\tn_phenos_tested\tn_qtls" > {output.tsv}
        for param in {params.params}; do
            type=$(echo $param | cut -d- -f1)
            par=$(echo $param | cut -d- -f2)
            n_bins=$(zcat $param/gene_bins/batch_*.bed.gz | wc -l)
            n_phenos=$(zcat $param/phenotypes/latent_phenos.Geuvadis.tsv.gz | tail -n+2 | wc -l)
            n_phenos_tested=$(cat qtl/latent-$param.phenotype_groups.txt | wc -l)
            n_qtls=$(zcat qtl/latent-$param.cis_independent_qtl.txt.gz | tail -n+2 | wc -l)
            echo -e "$type\t$par\t$n_bins\t$n_phenos\t$n_phenos_tested\t$n_qtls" >> {output.tsv}
        done
        """
