from pathlib import Path
import pandas as pd

configfile: 'config.yaml'

working_dir = Path('.')
benchmark_root = Path('..')
pantry_dir = benchmark_root / 'pantry'
benchmark_dir = benchmark_root / 'benchmarks' / 'laddr'


def benchmark_path(*parts) -> str:
    return str(benchmark_dir.joinpath(*[str(part) for part in parts]))


assert config['input']['coverage']['method'] == 'manifest'
sample_table = pd.read_csv(
    config['input']['coverage']['manifest'],
    sep='\t',
    names=['dataset', 'sample', 'path'],
)
if 'directory' in config['input']['coverage']:
    covg_dir = Path(config['input']['coverage']['directory'])
    sample_table['path'] = sample_table['path'].apply(lambda p: str(covg_dir / p))

datasets = sample_table['dataset'].unique().tolist()


rule all:
    input:
        expand(working_dir / 'phenotypes' / 'latent_phenos.{dataset}.tsv.gz', dataset=datasets),


rule bam_to_bigwig:
    input:
        bam=pantry_dir / 'intermediate' / 'bam' / '{sample}.bam',
        bai=pantry_dir / 'intermediate' / 'bam' / '{sample}.bam.bai',
    output:
        bw=working_dir / 'covg_bigwig' / '{sample}.bw',
    benchmark:
        benchmark_path('bigwig', '{sample}.tsv')
    conda: 'laddr'
    threads: 16
    shell:
        """
        mkdir -p {working_dir}/covg_bigwig
        bamCoverage -b {input.bam} -o {output.bw} --binSize 1 -p {threads}
        """


rule laddr_setup:
    input:
        config='config.yaml',
        manifest='coverage_manifest.tsv',
        bw=sample_table['path'].tolist(),
    output:
        genes=working_dir / 'info' / 'genes.tsv',
        exons=working_dir / 'info' / 'exons.tsv.gz',
        n_batches=working_dir / 'info' / 'n_batches.txt',
        median_covg=working_dir / 'info' / 'median_coverage.txt',
        var_per_bin=working_dir / 'info' / 'var_per_bin.txt',
    benchmark:
        benchmark_path('setup.tsv')
    conda: 'laddr'
    shell:
        """
        laddr setup -p {working_dir} -c {input.config}
        """


rule laddr_binning:
    input:
        config='config.yaml',
        setup=rules.laddr_setup.output,
        bw=sample_table['path'].tolist(),
    output:
        done=touch(working_dir / 'gene_bins' / '.done'),
    benchmark:
        benchmark_path('binning.tsv')
    conda: 'laddr'
    shell:
        """
        laddr binning -p {working_dir} -c {input.config}
        touch {output.done}
        """


rule laddr_coverage:
    input:
        config='config.yaml',
        bins=rules.laddr_binning.output.done,
        median_covg=working_dir / 'info' / 'median_coverage.txt',
        bw=sample_table['path'].tolist(),
    output:
        done=touch(working_dir / 'covg_norm' / '.done'),
    benchmark:
        benchmark_path('coverage.tsv')
    conda: 'laddr'
    shell:
        """
        laddr coverage -p {working_dir} -c {input.config}
        touch {output.done}
        """


rule laddr_fit:
    input:
        config='config.yaml',
        coverage=rules.laddr_coverage.output.done,
    output:
        done=touch(working_dir / 'models' / '.done'),
    benchmark:
        benchmark_path('fit.tsv')
    conda: 'laddr'
    shell:
        """
        laddr fit -p {working_dir} -c {input.config}
        touch {output.done}
        """


rule laddr_transform:
    input:
        config='config.yaml',
        coverage=rules.laddr_coverage.output.done,
        fit=rules.laddr_fit.output.done,
    output:
        phenos=working_dir / 'phenotypes' / 'latent_phenos.{dataset}.tsv.gz',
    benchmark:
        benchmark_path('transform', '{dataset}.tsv')
    conda: 'laddr'
    shell:
        """
        laddr transform -p {working_dir} -c {input.config} -d {wildcards.dataset}
        """
