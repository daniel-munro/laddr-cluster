from pathlib import Path
import pandas as pd

configfile: 'config.yaml'

working_dir = Path('.')
benchmark_root = Path('..')
pantry_dir = benchmark_root / 'pantry'
benchmark_dir = benchmark_root / 'benchmarks' / 'laddr'


def benchmark_path(*parts) -> str:
    return str(benchmark_dir.joinpath(*[str(part) for part in parts]))


assert config['input']['coverage']['method'] == 'manifest'
sample_table = pd.read_csv(
    config['input']['coverage']['manifest'],
    sep='\t',
    names=['dataset', 'sample', 'path'],
)
if 'directory' in config['input']['coverage']:
    covg_dir = Path(config['input']['coverage']['directory'])
    sample_table['path'] = sample_table['path'].apply(lambda p: str(covg_dir / p))

datasets = sample_table['dataset'].unique().tolist()
samples = sample_table['sample'].unique().tolist()


def get_n_batches() -> int:
    setup_output = checkpoints.laddr_setup.get()
    with open(setup_output.output.n_batches, 'r') as fh:
        return int(fh.read().strip())


def batch_indices():
    return range(get_n_batches())


def transform_covg_inputs(wildcards):
    return expand(
        str(working_dir / 'covg_norm' / wildcards.dataset / 'batch_{batch}.npy'),
        batch=batch_indices(),
    )


def transform_covg_bin_inputs(wildcards):
    return expand(
        str(working_dir / 'covg_norm' / wildcards.dataset / 'batch_{batch}.bins.tsv.gz'),
        batch=batch_indices(),
    )


def transform_model_inputs(wildcards):
    return expand(
        str(working_dir / 'models' / 'models_batch_{batch}.pickle'),
        batch=batch_indices(),
    )


def all_outputs(wildcards):
    checkpoints.laddr_setup.get()
    return expand(
        str(working_dir / 'phenotypes' / 'latent_phenos.{dataset}.tsv.gz'),
        dataset=datasets,
    )


rule all:
    input:
        all_outputs,


rule bam_to_bigwig:
    input:
        bam=pantry_dir / 'intermediate' / 'bam' / '{sample}.bam',
        bai=pantry_dir / 'intermediate' / 'bam' / '{sample}.bam.bai',
    output:
        bw=working_dir / 'covg_bigwig' / '{sample}.bw',
    benchmark:
        benchmark_path('bigwig', '{sample}.tsv')
    threads: 16
    resources:
        mem_mb=32000,
        runtime='8h',
    shell:
        """
        mkdir -p {working_dir}/covg_bigwig
        bamCoverage -b {input.bam} -o {output.bw} --binSize 1 -p {threads}
        """


checkpoint laddr_setup:
    input:
        config='config.yaml',
        manifest='coverage_manifest.tsv',
        bw=sample_table['path'].tolist(),
    output:
        genes=working_dir / 'info' / 'genes.tsv',
        exons=working_dir / 'info' / 'exons.tsv.gz',
        n_batches=working_dir / 'info' / 'n_batches.txt',
        median_covg=working_dir / 'info' / 'median_coverage.txt',
        var_per_bin=working_dir / 'info' / 'var_per_bin.txt',
    benchmark:
        benchmark_path('setup.tsv')
    resources:
        mem_mb=32000,
        runtime='12h',
    shell:
        """
        laddr setup -p {working_dir} -c {input.config}
        """


rule laddr_binning:
    input:
        genes=lambda w: checkpoints.laddr_setup.get().output.genes,
        exons=lambda w: checkpoints.laddr_setup.get().output.exons,
        var_per_bin=lambda w: checkpoints.laddr_setup.get().output.var_per_bin,
    output:
        beds=working_dir / 'gene_bins' / 'batch_{batch}.bed.gz',
    benchmark:
        benchmark_path('binning', '{batch}.tsv')
    resources:
        mem_mb=32000,
        runtime='24h',
    shell:
        """
        laddr binning -p {working_dir} -c config.yaml -b {wildcards.batch}
        """


rule laddr_coverage:
    input:
        bw=lambda w: sample_table.loc[sample_table['dataset'] == w.dataset, 'path'].tolist(),
        bins=working_dir / 'gene_bins' / 'batch_{batch}.bed.gz',
        median_covg=lambda w: checkpoints.laddr_setup.get().output.median_covg,
    output:
        covg=working_dir / 'covg_norm' / '{dataset}' / 'batch_{batch}.npy',
        covg_norm_bins=working_dir / 'covg_norm' / '{dataset}' / 'batch_{batch}.bins.tsv.gz',
    benchmark:
        benchmark_path('coverage', '{dataset}.batch_{batch}.tsv')
    resources:
        mem_mb=32000,
        runtime='12h',
    shell:
        """
        laddr coverage -p {working_dir} -c config.yaml -d {wildcards.dataset} -b {wildcards.batch}
        """


rule laddr_fit:
    input:
        covg_norm=expand(
            str(working_dir / 'covg_norm' / '{dataset}' / 'batch_{{batch}}.npy'),
            dataset=datasets,
        ),
        covg_norm_bins=expand(
            str(working_dir / 'covg_norm' / '{dataset}' / 'batch_{{batch}}.bins.tsv.gz'),
            dataset=datasets,
        ),
    output:
        models=working_dir / 'models' / 'models_batch_{batch}.pickle',
    benchmark:
        benchmark_path('fit', '{batch}.tsv')
    resources:
        mem_mb=32000,
        runtime='12h',
    shell:
        """
        laddr fit -p {working_dir} -c config.yaml -b {wildcards.batch}
        """


rule laddr_transform:
    input:
        covg_norm=transform_covg_inputs,
        covg_norm_bins=transform_covg_bin_inputs,
        models=transform_model_inputs,
    output:
        phenos=working_dir / 'phenotypes' / 'latent_phenos.{dataset}.tsv.gz',
    benchmark:
        benchmark_path('transform', '{dataset}.tsv')
    resources:
        mem_mb=32000,
        runtime='12h',
    shell:
        """
        laddr transform -p {working_dir} -c config.yaml -d {wildcards.dataset}
        """
