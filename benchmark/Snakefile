rule generate_bigwig:
    input:
        bam=PANTRY_DIR / "intermediate" / "bam" / "{sample}.bam",
        bai=PANTRY_DIR / "intermediate" / "bam" / "{sample}.bam.bai",
    output:
        LADDR_DIR / "covg_bigwig" / "{sample}.bw",
    benchmark:
        "benchmarks/laddr/bigwig/{sample}.tsv"
    conda: "latent"
    threads: 16
    shell:
        """
        mkdir -p {LADDR_DIR}/covg_bigwig
        bamCoverage -b {input.bam} -o {output} --binSize 1 -p {threads}
        """


rule pantry_alt_tss_polya:
    input:
        setup=rules.setup_projects.output.pantry_config,
        bam=expand(str(PANTRY_DIR / "intermediate" / "bam" / "{sample}.bam"), sample=samples),
        bai=expand(str(PANTRY_DIR / "intermediate" / "bam" / "{sample}.bam.bai"), sample=samples),
    output:
        PANTRY_DIR / "output" / "alt_TSS.bed.gz",
        PANTRY_DIR / "output" / "alt_TSS.bed.gz.tbi",
        PANTRY_DIR / "output" / "alt_TSS.phenotype_groups.txt",
        PANTRY_DIR / "output" / "alt_polyA.bed.gz",
        PANTRY_DIR / "output" / "alt_polyA.bed.gz.tbi",
        PANTRY_DIR / "output" / "alt_polyA.phenotype_groups.txt",
    benchmark:
        "benchmarks/pantry/alt_TSS_polyA.tsv"
    conda: "pantry"
    threads: PANTRY_THREADS
    shell:
        """
        cd {PANTRY_DIR}
        snakemake --cores {threads} --snakefile Snakefile \
            output/alt_TSS.bed.gz \
            output/alt_TSS.bed.gz.tbi \
            output/alt_TSS.phenotype_groups.txt \
            output/alt_polyA.bed.gz \
            output/alt_polyA.bed.gz.tbi \
            output/alt_polyA.phenotype_groups.txt
        """


rule pantry_expression_isoforms:
    input:
        setup=rules.setup_projects.output.pantry_config,
    output:
        PANTRY_DIR / "output" / "expression.bed.gz",
        PANTRY_DIR / "output" / "expression.bed.gz.tbi",
        PANTRY_DIR / "output" / "isoforms.bed.gz",
        PANTRY_DIR / "output" / "isoforms.bed.gz.tbi",
        PANTRY_DIR / "output" / "isoforms.phenotype_groups.txt",
    benchmark:
        "benchmarks/pantry/expression_isoforms.tsv"
    conda: "pantry"
    threads: PANTRY_THREADS
    shell:
        """
        cd {PANTRY_DIR}
        snakemake --cores {threads} \
            output/expression.bed.gz \
            output/expression.bed.gz.tbi \
            output/isoforms.bed.gz \
            output/isoforms.bed.gz.tbi \
            output/isoforms.phenotype_groups.txt
        """


rule pantry_splicing:
    input:
        setup=rules.setup_projects.output.pantry_config,
        bam=expand(str(PANTRY_DIR / "intermediate" / "bam" / "{sample}.bam"), sample=samples),
        bai=expand(str(PANTRY_DIR / "intermediate" / "bam" / "{sample}.bam.bai"), sample=samples),
    output:
        PANTRY_DIR / "output" / "splicing.bed.gz",
        PANTRY_DIR / "output" / "splicing.bed.gz.tbi",
        PANTRY_DIR / "output" / "splicing.phenotype_groups.txt",
    benchmark:
        "benchmarks/pantry/splicing.tsv"
    conda: "pantry"
    threads: PANTRY_THREADS
    shell:
        """
        cd {PANTRY_DIR}
        snakemake --cores {threads} \
            output/splicing.bed.gz \
            output/splicing.bed.gz.tbi \
            output/splicing.phenotype_groups.txt
        """


rule pantry_stability:
    input:
        setup=rules.setup_projects.output.pantry_config,
        bam=expand(str(PANTRY_DIR / "intermediate" / "bam" / "{sample}.bam"), sample=samples),
        bai=expand(str(PANTRY_DIR / "intermediate" / "bam" / "{sample}.bam.bai"), sample=samples),
    output:
        PANTRY_DIR / "output" / "stability.bed.gz",
        PANTRY_DIR / "output" / "stability.bed.gz.tbi",
    benchmark:
        "benchmarks/pantry/stability.tsv"
    conda: "pantry"
    threads: THREADS
    shell:
        """
        cd {PANTRY_DIR}
        snakemake --cores {threads} \
            output/stability.bed.gz \
            output/stability.bed.gz.tbi
        """


rule laddr_setup:
    input:
        config=LADDR_DIR / "config.yaml",
        manifest=LADDR_DIR / "coverage_manifest.tsv",
        bw=expand(str(LADDR_DIR / "covg_bigwig" / "{sample}.bw"), sample=samples),
    output:
        LADDR_DIR / "info" / "genes.tsv",
        LADDR_DIR / "info" / "exons.tsv.gz",
        LADDR_DIR / "info" / "n_batches.txt",
        LADDR_DIR / "info" / "median_coverage.txt",
    benchmark:
        "benchmarks/laddr/setup.tsv"
    conda: "latent"
    shell:
        """
        laddr setup -p {LADDR_DIR} -c {input.config}
        """


rule laddr_binning:
    input:
        setup=rules.laddr_setup.output,
    output:
        LADDR_DIR / "gene_bins",
    benchmark:
        "benchmarks/laddr/binning.tsv"
    conda: "latent"
    shell:
        """
        laddr binning -p {LADDR_DIR} -c {rules.setup_projects.output.laddr_config}
        """


rule laddr_coverage:
    input:
        setup=rules.setup_projects.output.laddr_config,
        manifest=rules.setup_projects.output.laddr_manifest,
        info=rules.laddr_setup.output,
        bins=rules.laddr_binning.output,
        bw=expand(str(LADDR_DIR / "covg_bigwig" / "{sample}.bw"), sample=samples),
    output:
        LADDR_DIR / "covg_norm" / DATASET_NAME / ".coverage_done",
    benchmark:
        "benchmarks/laddr/coverage.tsv"
    conda: "latent"
    shell:
        """
        laddr coverage -p {LADDR_DIR} -c {input.setup} -d {DATASET_NAME}
        touch {output}
        """


rule laddr_fit:
    input:
        config=rules.setup_projects.output.laddr_config,
        coverage=rules.laddr_coverage.output,
    output:
        LADDR_DIR / "models" / ".fit_done",
    benchmark:
        "benchmarks/laddr/fit.tsv"
    conda: "latent"
    shell:
        """
        laddr fit -p {LADDR_DIR} -c {input.config}
        touch {output}
        """


rule laddr_transform:
    input:
        config=rules.setup_projects.output.laddr_config,
        coverage=rules.laddr_coverage.output,
        fit=rules.laddr_fit.output,
    output:
        LADDR_DIR / "phenotypes" / f"latent_phenos.{DATASET_NAME}.tsv.gz",
    benchmark:
        "benchmarks/laddr/transform.tsv"
    conda: "latent"
    shell:
        """
        laddr transform -p {LADDR_DIR} -c {input.config} -d {DATASET_NAME}
        """


rule summarize_benchmarks:
    input:
        alignment=benchmark_files("alignment/star_align", samples)
        + benchmark_files("pantry/shrink_bam", samples)
        + benchmark_files("alignment/index_bam", samples),
        bigwig=benchmark_files("laddr/bigwig", samples),
        pantry=[
            "benchmarks/pantry/alt_TSS_polyA.tsv",
            "benchmarks/pantry/expression_isoforms.tsv",
            "benchmarks/pantry/splicing.tsv",
            "benchmarks/pantry/stability.tsv",
        ],
        laddr=[
            "benchmarks/laddr/setup.tsv",
            "benchmarks/laddr/binning.tsv",
            "benchmarks/laddr/coverage.tsv",
            "benchmarks/laddr/fit.tsv",
            "benchmarks/laddr/transform.tsv",
        ],
    output:
        tsv="results/benchmark_summary.tsv",
        csv="results/benchmark_summary.csv",
    params:
        samples=N_SAMPLES,
        pantry_threads=PANTRY_THREADS,
        bigwig_threads=BIGWIG_THREADS,
    shell:
        """
        mkdir -p results
        python3 scripts/summarize_benchmarks.py \
            --samples {params.samples} \
            --pantry-threads {params.pantry_threads} \
            --bigwig-threads {params.bigwig_threads} \
            --output-tsv {output.tsv} \
            --output-csv {output.csv}
        """
