"""Benchmark GEUVADIS phenotyping runtime for Pantry and LaDDR on 100 samples."""

from pathlib import Path
import csv

PANTRY_DIR = Path(config["pantry_project_dir"])
SHARED_DIR = Path(config["shared_work_dir"])
LADDR_DIR = Path(config["laddr_project_dir"])

sample_list = Path("../seqsim/data/samples.txt")
# fastq_map_file = Path("../../data/geuvadis/fastq_map.txt")
# fastq_dir = Path("../../data/geuvadis/fastq")
# ref_genome = Path("../../ref/human/GRCh38_no_alt_analysis_set_GCA_000001405.15.fasta")
# ref_anno = Path("../../ref/human-ensembl/Homo_sapiens.GRCh38.113.chr.chrom.gtf")
# star_index_dir = Path("../seqsim/data/bam/reference/star_index_75")

BIGWIG_THREADS = 16
PANTRY_THREADS = 16

N_SAMPLES = int(config["benchmark"]["samples"])
DATASET_NAME = config["benchmark"]["dataset_name"]

with open(sample_list, "r") as fh:
    samples = [line.strip() for line in fh if line.strip()]

if len(samples) != N_SAMPLES:
    raise ValueError(
        f"Expected {N_SAMPLES} samples in {sample_list}, found {len(samples)}"
    )

fastq_pairs = {}
with open(fastq_map_file, "r") as fh:
    reader = csv.reader(fh, delimiter="\t")
    for row in reader:
        fastq_pairs[row[2]] = (
            str(fastq_dir / row[0]),
            str(fastq_dir / row[1]),
        )


def fastq_inputs(wildcards):
    return fastq_pairs[wildcards.sample]


def benchmark_files(prefix, values):
    return expand(str(Path("benchmarks") / prefix / "{value}.tsv"), value=values)


localrules:
    setup_projects,

rule all:
    input:
        "results/benchmark_summary.tsv",
        "results/benchmark_summary.csv",


