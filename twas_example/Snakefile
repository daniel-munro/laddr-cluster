"""Extract data relevant to TWAS hits of interest to plot as examples

- Mean binned coverage and high vs. low sample mean coverage for the gene
- TWAS weights for the phenotype to plot alongside GWAS z-scores
- GWAS sumstat z-scores within the gene range
"""

import pandas as pd

phenos = pd.read_csv('example_phenos_all.tsv', sep='\t')
ids = phenos.phenotype_id.tolist()
genes = phenos.gene_id.unique().tolist()
gene_tissue_pairs = [f'{row["gene_id"]}.{row["tissue"]}' for _, row in phenos.iterrows()]
id_tissue_pairs = [f'{row["phenotype_id"]}.{row["tissue"]}' for _, row in phenos.iterrows()]
trait_gene_pairs = [f'{row["trait"]}-{row["gene_id"]}' for _, row in phenos.iterrows()]

gene_info = pd.read_csv('../phenos/gtextcga-full/info/genes.tsv', sep='\t')
gene_info = gene_info[gene_info.gene_id.isin(genes)]

localrules:
    copy_model_info,
    copy_weights,
    gwas_sumstats,

rule all:
    input:
        expand('model_info/inspect.{gene_tissue}.tsv.gz', gene_tissue=gene_tissue_pairs),
        expand('weights/{pheno_tissue}.wgt.RDat', pheno_tissue=id_tissue_pairs),
        expand('gwas/{trait_gene}.tsv.gz', zip, trait_gene=trait_gene_pairs),

rule get_model_info:
    input:
        phenos = '../phenos/gtextcga-full/phenotypes/latent_phenos.{tissue}.tsv.gz',
    output:
        tsv = '../phenos/gtextcga-full/inspect/inspect.{gene}.{tissue}.tsv.gz',
    params:
        pheno_dir = '../phenos/gtextcga-full/',
    shell:
        'laddr inspect -p {params.pheno_dir} -d {wildcards.tissue} -g {wildcards.gene}'

rule copy_model_info:
    input:
        tsv = '../phenos/gtextcga-full/inspect/inspect.{gene}.{tissue}.tsv.gz',
    output:
        tsv = 'model_info/inspect.{gene}.{tissue}.tsv.gz',
    shell:
        'cp {input.tsv} {output.tsv}'

rule copy_weights:
    input:
        wgt = '../pheast/gtextcga-full/intermediate/twas/{tissue}-latent/{id}.wgt.RDat',
    output:
        wgt = 'weights/{id}.{tissue}.wgt.RDat',
    shell:
        'cp {input.wgt} {output.wgt}'

rule gwas_sumstats:
    input:
        gwas = '../../data/gwas/imputed_gwas_hg38_1.1/imputed_{trait}.txt.gz',
    output:
        tsv = 'gwas/{trait}-{gene}.tsv.gz',
    params:
        chrom = lambda w: gene_info.seqname[gene_info.gene_id == w.gene].values[0],
        start = lambda w: gene_info.tss[gene_info.gene_id == w.gene].values[0] - 500000,
        end = lambda w: gene_info.tss[gene_info.gene_id == w.gene].values[0] + 500000,
    shell:
        """
        zcat {input.gwas} \
            | awk -v chrom={params.chrom} -v start={params.start} -v end={params.end} 'NR==1 || ($3 == chrom && $4 >= start && $4 <= end)' \
            | gzip -c \
            > {output.tsv}
    """
